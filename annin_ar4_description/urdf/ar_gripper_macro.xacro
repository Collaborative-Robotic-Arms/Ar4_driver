<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="ar_gripper" params="
    tf_prefix
    parent
  ">

    <joint name="${tf_prefix}gripper_base_joint" type="fixed">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
      <parent link="${parent}" />
      <child link="${tf_prefix}gripper_base_link" />
    </joint>

    <link name="${tf_prefix}gripper_base_link">
      <visual>
        <geometry>
          <mesh
            filename="file://$(find annin_ar4_description)/meshes/ar4_gripper/gripper_base_link.STL" />
        </geometry>
        <material name="">
          <color rgba="1 1 0 1" />
        </material>
      </visual>
      <collision>
        <geometry>
          <mesh
            filename="file://$(find annin_ar4_description)/meshes/ar4_gripper/gripper_base_link.STL" />
        </geometry>
      </collision>
      <inertial>
        <origin
          xyz="0.000218865638025569 0.0025824189928268 0.0188189080442559"
          rpy="0 0 0" />
        <mass
          value="0.0779213197542101" />
        <inertia
          ixx="1.27018244320936E-05"
          ixy="-1.98293669536147E-07"
          ixz="-2.58632439119383E-07"
          iyy="2.84792796640278E-05"
          iyz="-4.25276765641554E-07"
          izz="3.57075748419373E-05" />
      </inertial>
    </link>

    <link name="${tf_prefix}gripper_jaw1_link">
      <visual>
        <geometry>
          <mesh
            filename="file://$(find annin_ar4_description)/meshes/ar4_gripper/gripper_jaw1_link.STL" />
        </geometry>
        <material name="">
          <color rgba="1 1 0 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="-0.024 0.0 0.065" rpy="0 0 0" /> 
        <geometry>
          <box size="0.007 0.018 0.035" /> 
        </geometry>
      </collision>
      <inertial>
        <origin
          xyz="-0.0031054 -0.0019355 0.0098549"
          rpy="0 0 0" />
        <mass
          value="0.0066046" />
        <inertia
          ixx="1.5783E-06"
          ixy="1.1866E-07"
          ixz="1.5325E-07"
          iyy="1.3594E-06"
          iyz="-2.2561E-07"
          izz="6.2333E-07" />
      </inertial>
    </link>

    <link name="${tf_prefix}gripper_jaw2_link">
      <visual>
        <geometry>
          <mesh
            filename="file://$(find annin_ar4_description)/meshes/ar4_gripper/gripper_jaw2_link.STL" />
        </geometry>
        <material name="">
          <color rgba="1 1 0 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0.024 0.0 0.065" rpy="0 0 0" /> 
        <geometry>
          <box size="0.007 0.018 0.035" /> 
        </geometry>
      </collision>
      <inertial>
        <origin xyz="-0.00423971 -0.00491236 0.00814582" />
        <mass value="0.01" />
        <inertia ixx="0.00000118" ixy="-0.00000004" ixz="0.00000013" iyy="0.00000110"
          iyz="0.00000013" izz="0.00000101" />
      </inertial>
    </link>

    <joint name="${tf_prefix}gripper_jaw1_joint" type="prismatic">
      <origin xyz="0.0 -0.00026 0.0" rpy="0 0 0" />
      <parent link="${tf_prefix}gripper_base_link" />
      <child link="${tf_prefix}gripper_jaw1_link" />
      <axis xyz="1 0 0" />
      <limit lower="0.0" upper="0.015" effort="20" velocity="1.0" />
    </joint>

    <joint name="${tf_prefix}gripper_jaw2_joint" type="prismatic">
      <origin xyz="0.0 -0.00026 0.0" rpy="0 0 0" />
      <parent link="${tf_prefix}gripper_base_link" />
      <child link="${tf_prefix}gripper_jaw2_link" />
      <axis xyz="-1 0 0" />
      <limit lower="0.0" upper="0.015" effort="20" velocity="1.0" />
    </joint>
    
    <gazebo reference="${tf_prefix}gripper_jaw1_link">
      <surface>
        <friction>
          <torsional>
            <ode>
              <coefficient>100.0</coefficient>
              <use_patch_radius>true</use_patch_radius>
              <patch_radius>0.015</patch_radius>
            </ode>
          </torsional>
          <ode>
            <mu>100.0</mu>
            <mu2>100.0</mu2>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
          </ode>
        </friction>
        <contact>
          <ode>
            <max_vel>0.0</max_vel>
            <min_depth>0.001</min_depth>
            <kp>1000000.0</kp>
            <kd>1.0</kd>
          </ode>
        </contact>
      </surface>
    </gazebo>

    <gazebo reference="${tf_prefix}gripper_jaw2_link">
      <surface>
        <friction>
          <torsional>
            <ode>
              <coefficient>100.0</coefficient>
              <use_patch_radius>true</use_patch_radius>
              <patch_radius>0.015</patch_radius>
            </ode>
          </torsional>
          <ode>
            <mu>100.0</mu>
            <mu2>100.0</mu2>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
          </ode>
        </friction>
        <contact>
          <ode>
            <max_vel>0.0</max_vel>
            <min_depth>0.001</min_depth>
            <kp>1000000.0</kp>
            <kd>1.0</kd>
          </ode>
        </contact>
      </surface>
    </gazebo>
  </xacro:macro>
</robot>